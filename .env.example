# Copy this file to .env.local and fill in the values.

# Encryption key used to protect subscriber data.
# Use a 32-byte secret or a base64-encoded 32-byte secret (prefix with base64:).
SUBSCRIBER_STORE_KEY=base64:Y2xvdWQgaW1hZ2luZSBhIGJhc2U2NCBrZXk=

# Admin credentials for viewing encrypted subscriber data
ADMIN_USER=admin
ADMIN_PASS=changeme

